+            // connection permanently stops ALL camera events (no motion alerts, no HKSV
+            // recording triggers) until Homebridge is restarted. Here we re-subscribe on
+            // 'error'/'close' with exponential backoff (5s..60s), reset on healthy traffic.
+            this._nestReconnectDelay = 5000;
+            this._nestSubscribe = () => {
+                // Capture the subscription in a closure local; tear THIS one down on reconnect
+                // (not this.subscription, which a future path could have already replaced).
+                const sub = this.pubSubClient.subscription(config.subscriptionId);
+                this.subscription = sub;
+                this.subscribed = true;
+                let reconnectScheduled = false;
+                const reconnect = (reason, error) => {
+                    if (reconnectScheduled)
